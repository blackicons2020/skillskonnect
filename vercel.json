{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api(.*)",
      "destination": "/api/server-mongo.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
